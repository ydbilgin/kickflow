{
  "manifest_version": 3,
  "name": "KickFlow",
  "version": "1.0.0",
  "description": "Personal-use Kick.com companion: preserves banned/deleted chat messages and adds player quality-of-life (fixed highest quality, live catch-up, arrow-key seek).",
  "permissions": ["storage", "activeTab"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "KickFlow",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://kick.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://kick.com/*"],
      "js": ["dist/mainworld.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
